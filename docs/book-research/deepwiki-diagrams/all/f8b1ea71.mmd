flowchart TD
    TEMPLATE["Template File<br/>{name}-template.md"]
    
    TEMPLATE --> BANNER["1. Template Origin Banner<br/>Lines 1-3"]
    BANNER --> DOCCTL["2. Document Control Table<br/>14 required fields"]
    DOCCTL --> REVHIST["3. Revision History Table<br/>Version tracking"]
    REVHIST --> BODY["4. Content Body<br/>Command-specific sections"]
    BODY --> FOOTER["5. Generation Footer<br/>Metadata and attribution"]
    
    BANNER --> BANNER_EX["'Template Origin: Official'<br/>'ArcKit Version: [VERSION]'<br/>'Command: /arckit.{name}'"]
    
    DOCCTL --> DOCCTL_EX["Document ID, Classification<br/>Status, Version, Owner<br/>Review Cycle, Approvers"]
    
    REVHIST --> REVHIST_EX["Version | Date | Author<br/>Changes | Approved By"]
    
    BODY --> BODY_EX["## Sections with ##<br/>Tables and lists<br/>Mermaid diagrams<br/>Placeholder variables"]
    
    FOOTER --> FOOTER_EX["'Generated by: ArcKit...'<br/>'Generated on: [DATE]'<br/>'ArcKit Version: [VERSION]'"]
