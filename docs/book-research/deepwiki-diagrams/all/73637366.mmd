graph TB
    PROMPT["User prompt string"]
    RAW{"Raw slash<br/>command?"}
    EXPANDED{"Skill-expanded<br/>body?"}
    UNIQUE["Match unique strings:<br/>'Generate documen...'<br/>OR 'ArcKit: Documentation...'"]
