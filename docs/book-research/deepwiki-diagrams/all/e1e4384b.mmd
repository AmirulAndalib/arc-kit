graph TB
    subgraph "Session Lifecycle"
        START["SessionStart<br/>init-arckit-version.mjs"]
        PROMPT["UserPromptSubmit<br/>arckit-context.mjs<br/>health-scan.mjs<br/>traceability-scan.mjs"]
    end
    
    subgraph "Tool Execution"
        PRE["PreToolUse<br/>validate-arc-filename.mjs"]
        WRITE["Write Tool Executes"]
