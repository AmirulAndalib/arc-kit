graph TB
    subgraph "Initial Load"
        LoadPage["Load index.html<br/>(~150KB with embedded CSS/JS)"]
        LoadManifest["fetch manifest.json<br/>(~5-50KB depending on project count)"]
        RenderNav["Render navigation tree<br/>(client-side DOM construction)"]
    end
    
    subgraph "Document Loading"
        LazyLoad["Documents not loaded<br/>until user clicks"]
        CheckCache{"Document in<br/>cache?"}
        CheckCache -->|Yes| UseCache["Use cached content<br/>(instant)"]
        CheckCache -->|No| FetchRemote["fetch from raw.githubusercontent.com<br/>(~1-2s)"]
        FetchRemote --> CacheDoc["Store in documentCache object"]
    end
    
    subgraph "Rendering Optimization"
        AsyncMermaid["mermaid.run() async<br/>(non-blocking)"]
        IncrementalTOC["Build TOC from existing DOM<br/>(no re-parse)"]
        Debounce["Debounce search input<br/>(300ms delay)"]
    end
