graph TB
    subgraph "Hook Data Sufficient (Zero File Reads)"
        PassA_Check["Pass A:<br/>Requirements Quality<br/>(all data in<br/>Requirements Inventory table)"]
        PassC_Check["Pass C:<br/>Traceability<br/>(all data in<br/>Coverage Summary)"]
        PassK_Check["Pass K:<br/>Consistency<br/>(all data in<br/>Document Control fields)"]
    end
    
    subgraph "Targeted Read Needed (1-3 File Operations)"
        PassB_Check["Pass B:<br/>Principles Alignment<br/>(need full validation<br/>criteria for violations)"]
        PassF_Check["Pass F:<br/>Risk Management<br/>(need Risk Appetite<br/>thresholds)"]
        PassI_Check["Pass I:<br/>UK Gov Compliance<br/>(need per-point scores<br/>from TCOP/AIPB)"]
    end
    
    PassB_Check --> GrepPRIN["Grep '### 5. Cloud' in<br/>projects/000-global/ARC-000-PRIN-*.md<br/>(get one principle's full criteria)"]
    
    PassF_Check --> GrepRISK["Grep 'Risk Appetite' in<br/>projects/001-*/ARC-*-RISK-*.md<br/>(then Read offset=N limit=20)"]
    
    PassI_Check --> GrepTCOP["Read ARC-001-TCOP-v1.0.md<br/>offset=50 limit=30<br/>(get scoring table only)"]
    
    GrepPRIN --> Findings
    GrepRISK --> Findings
    GrepTCOP --> Findings
    
    PassA_Check -.->|Zero reads| Findings
    PassC_Check -.->|Zero reads| Findings
    PassK_Check -.->|Zero reads| Findings
    
    Findings["Detection Pass Findings"]
    
    style PassA_Check fill:#d4edda
    style PassC_Check fill:#d4edda
    style PassK_Check fill:#d4edda
    style PassB_Check fill:#fff3cd
    style PassF_Check fill:#fff3cd
