graph LR
    Input["Input:<br/>vendor.name or tech.name"]
    
    Step1["toLowerCase()"]
    Step2["replace(/\\s+/g, '-')<br/>Spaces to hyphens"]
    Step3["replace(/[^a-z0-9-]/g, '')<br/>Remove special chars"]
