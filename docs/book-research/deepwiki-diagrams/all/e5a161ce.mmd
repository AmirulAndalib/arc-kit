graph LR
    COMMITS["Git Commits"]
    FILTER["Commit Filter Logic"]
    
    subgraph "Included"
        FEAT["feat: New features<br/>창혛혪 ### Added"]
        FIX["fix: Bug fixes<br/>창혛혪 ### Fixed"]
        BREAKING["BREAKING CHANGE:<br/>창혛혪 ### Changed"]
        DOCS["docs: Documentation<br/>창혛혪 ### Changed"]
        REFACTOR["refactor: Code changes<br/>창혛혪 ### Changed"]
    end
    
    subgraph "Excluded"
        CHORE["chore: Maintenance"]
        TEST["test: Test updates"]
        STYLE["style: Formatting"]
        BUILD["build: Build system"]
    end
    
    COMMITS --> FILTER
    FILTER -->|"parse type"| FEAT
    FILTER -->|"parse type"| FIX
    FILTER -->|"parse body"| BREAKING
    FILTER -->|"user-facing"| DOCS
    FILTER -->|"significant"| REFACTOR
    FILTER -.->|"silent"| CHORE
    FILTER -.->|"silent"| TEST
    FILTER -.->|"silent"| STYLE
    FILTER -.->|"silent"| BUILD
